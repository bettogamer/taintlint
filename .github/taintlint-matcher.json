{
  "problemMatcher": [
    {
      "owner": "taintlint",
      "pattern": [
        {
          "regexp": "^(.+):(\\d+):(\\d+)\\s+(ERROR|WARNING)\\s+(SV\\d{3})\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      ]
    }
  ]
}
