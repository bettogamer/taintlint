{
  "name": "taintlint",
  "version": "0.1.0",
  "description": "Static analysis for WoW addon Lua — catch secret value (12.0+) errors before they hit the raid.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bettogamer/taintlint.git"
  },
  "homepage": "https://github.com/bettogamer/taintlint#readme",
  "bugs": "https://github.com/bettogamer/taintlint/issues",
  "bin": {
    "taintlint": "src/cli.ts"
  },
  "files": [
    "src/",
    "db/",
    "assets/logo.svg"
  ],
  "scripts": {
    "test": "node --test \"test/*.test.ts\"",
    "lint": "node src/cli.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "wow",
    "world-of-warcraft",
    "addon",
    "lua",
    "lint",
    "static-analysis",
    "secret-values",
    "taint",
    "midnight"
  ],
  "dependencies": {
    "luaparse": "^0.3.1"
  },
  "devDependencies": {
    "@types/luaparse": "^0.2.13",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
